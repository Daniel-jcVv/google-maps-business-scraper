# ============================================================================
# GAS STATION ANALYZER - ENVIRONMENT TEMPLATE
# ============================================================================
# Copy this file to .env and fill in your credentials
# cp .env.example .env
# ============================================================================

# ----------------------------------------------------------------------------
# N8N INSTANCE CONFIGURATION
# ----------------------------------------------------------------------------
N8N_BASE_URL=http://localhost:5678
N8N_EMAIL=your.email@example.com
N8N_PASSWORD=your_password_here

# N8N MCP Server (optional)
N8N_MCP_BASE_URL=http://localhost:5678/mcp-server/http
N8N_MCP_ACCESS_TOKEN=

# N8N Public API Token (optional)
N8N_API_TOKEN=

# ----------------------------------------------------------------------------
# EXTERNAL API CREDENTIALS
# ----------------------------------------------------------------------------

# Apify API (Required) - Google Maps Scraping
# Get your API key at: https://console.apify.com/account/integrations
APIFY_API_KEY=your_apify_api_key_here

# Firecrawl API (Optional) - Website Content Extraction
# Get your API key at: https://firecrawl.dev/
FIRECRAWL_API_KEY=

# ----------------------------------------------------------------------------
# GOOGLE CLOUD CREDENTIALS (Required)
# ----------------------------------------------------------------------------

# Google Cloud Console - OAuth 2.0 Client
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_API_KEY=

# Gmail API Credentials (Optional - for notifications)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# ----------------------------------------------------------------------------
# GOOGLE SHEETS CONFIGURATION
# ----------------------------------------------------------------------------

# Target Spreadsheet for Data Storage
GOOGLE_SHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID

# Sheet Names (customize if needed)
SHEET_QUERY=Query
SHEET_DATA=Data
SHEET_DETAILS=Details

# ----------------------------------------------------------------------------
# AIRTABLE CONFIGURATION (Optional - Alternative Storage)
# ----------------------------------------------------------------------------
AIRTABLE_API_KEY=

# ----------------------------------------------------------------------------
# APPLICATION SETTINGS
# ----------------------------------------------------------------------------

# Scraping Configuration
MAX_PLACES_PER_SEARCH=15
SCRAPING_LANGUAGE=en
ENABLE_WEBSITE_EXTRACTION=false

# Decision Score Weights (must sum to 100)
WEIGHT_RATING=40
WEIGHT_REVIEWS=30
WEIGHT_24HOURS=30

# Scheduling
SCHEDULE_INTERVAL_MINUTES=30
