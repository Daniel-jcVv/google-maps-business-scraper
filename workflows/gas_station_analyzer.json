    {
      "parameters": {
        "jsCode": "/**\n * Transform Apify data and calculate Decision Score\n * Uses same formula as src/scorer.py (tested with 100% coverage)\n */\n\nfunction calculateDecisionScore(rating, totalReviews, open24Hours) {\n  // Input validation (same as Python version)\n  if (rating < 0 || rating > 5) {\n    throw new Error(`Rating ${rating} must be between 0 and 5`);\n  }\n  if (totalReviews < 0) {\n    throw new Error(`Reviews ${totalReviews} cannot be negative`);\n  }\n  \n  // Score components (matching Python formula exactly)\n  const ratingScore = (rating / 5) * 40;\n  const reviewsScore = Math.min(Math.log10(totalReviews + 1) * 10, 30);\n  const availabilityScore = open24Hours ? 30 : 0;\n  \n  // Return rounded integer\n  return Math.round(ratingScore + reviewsScore + availabilityScore);\n}\n\n// Process all items from Apify\nconst items = $input.all();\n\nreturn items.map(item => ({\n  json: {\n    Station_ID: item.json.placeId || '',\n    Station_Name: item.json.title || '',\n    Address: item.json.address || 'N/A',\n    Latitude: item.json.location?.lat || 0,\n    Longitude: item.json.location?.lng || 0,\n    Rating_Average: item.json.totalScore || 0,\n    Total_Reviews: item.json.reviewsCount || 0,\n    Open_24_Hours: (item.json.openingHours || []).every(d => d.hours?.includes('24 hours')),\n    Google_Maps_URL: item.json.url || '',\n    Decision_Score: calculateDecisionScore(\n      item.json.totalScore || 0,\n      item.json.reviewsCount || 0,\n      (item.json.openingHours || []).every(d => d.hours?.includes('24 hours'))\n    )\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -400,
        336
      ],
